{%- comment -%}
  Product Highlight — up to 4 merchant-selected products shown as a selector
  row plus one large "featured" panel. Selecting a product updates the featured
  panel client-side (no reload), since every product is rendered up front.

  Note: as a web component it re-initialises itself when the theme editor
  re-renders the section, this way, it also has room to grow (e.g. a carousel).
{%- endcomment -%}

{{ 'product-highlight.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-highlight.js' | asset_url }}" type="module"></script>

{%- comment -%} We've used a css variable and the {{ section-id }} to keep styles unique to each section placed. {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} .product-highlight {
    --ph-gap: {{ section.settings.gap | default: 16 }}px;
  }
{%- endstyle -%}

<div class="product-highlight-wrapper">
  {%- if section.settings.heading != blank -%}
    <h2 class="product-highlight__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  {%- assign product_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.product != blank -%}
      {%- assign product_count = product_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if product_count == 0 -%}
    {%- comment -%} Empty state keeps the section from looking broken in the editor. {%- endcomment -%}
    <p class="product-highlight__empty">
      {{ 'No products selected yet. Add up to 4 products in the theme editor.' }}
    </p>
  {%- else -%}
    {%- assign select_label = 'Select' -%}
    {%- assign selected_label = 'Selected' -%}
    {%- assign panel_id = section.id | append: '-ph-panel' -%}

    {%- assign featured_index = -1 -%}
    {%- for block in section.blocks -%}
      {%- if block.settings.product != blank and featured_index == -1 -%}
        {%- assign featured_index = forloop.index0 -%}
      {%- endif -%}
    {%- endfor -%}

    <product-highlight
      class="product-highlight"
      data-section-id="{{ section.id }}"
      data-label-select="{{ select_label | escape }}"
      data-label-selected="{{ selected_label | escape }}"
    >
      {%- for block in section.blocks -%}
        {%- if block.settings.product != blank and forloop.index0 == featured_index -%}
          {%- assign product = block.settings.product -%}
          {%- capture featured_price -%}{% if product.price_varies %}{{ product.price_min | money }} – {{ product.price_max | money }}{% else %}{{ product.price | money }}{% endif %}{%- endcapture -%}
          <div
            class="product-highlight__featured"
            data-featured
            id="{{ panel_id }}"
            role="tabpanel"
            tabindex="0"
            aria-labelledby="{{ section.id }}-ph-tab-{{ featured_index }}"
            {{ block.shopify_attributes }}
          >
            <a class="product-highlight__featured-link" data-featured-link href="{{ product.url }}">
              {%- if product.featured_image -%}
                <img
                  class="product-highlight__featured-image"
                  data-featured-image
                  src="{{ product.featured_image | image_url: width: 800, height: 800, crop: 'center' }}"
                  srcset="{{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' }} 400w,
                          {{ product.featured_image | image_url: width: 800, height: 800, crop: 'center' }} 800w"
                  sizes="(min-width: 750px) 50vw, 100vw"
                  width="800"
                  height="800"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'product-highlight__featured-image product-highlight__placeholder' }}
              {%- endif -%}
            </a>
            <div class="product-highlight__featured-info">
              <h3 class="product-highlight__featured-title" data-featured-title>{{ product.title | escape }}</h3>
              <p class="product-highlight__featured-price" data-featured-price>{{ featured_price }}</p>
              <a
                class="product-highlight__view"
                data-featured-cta
                href="{{ product.url }}"
                aria-label="View product: {{ product.title | escape }}"
              >View product</a>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <ul class="product-highlight__list" role="tablist" aria-label="{{ section.settings.heading | default: 'Highlighted products' | escape }}">
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            {%- assign product = block.settings.product -%}
            {%- assign is_selected = false -%}
            {%- if forloop.index0 == featured_index -%}{%- assign is_selected = true -%}{%- endif -%}
            {%- capture price_text -%}{% if product.price_varies %}{{ product.price_min | money }} – {{ product.price_max | money }}{% else %}{{ product.price | money }}{% endif %}{%- endcapture -%}
            <li class="product-highlight__item" {{ block.shopify_attributes }}>
              <button
                type="button"
                class="product-highlight__selector"
                id="{{ section.id }}-ph-tab-{{ forloop.index0 }}"
                role="tab"
                aria-controls="{{ panel_id }}"
                aria-selected="{{ is_selected }}"
                tabindex="{% if is_selected %}0{% else %}-1{% endif %}"
                data-selector
                data-index="{{ forloop.index0 }}"
                data-title="{{ product.title | escape }}"
                data-price="{{ price_text | strip_html | strip | escape }}"
                data-url="{{ product.url }}"
                data-image="{{ product.featured_image | image_url: width: 800, height: 800, crop: 'center' }}"
                data-image-400="{{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' }}"
                data-image-alt="{{ product.featured_image.alt | escape }}"
              >
                <span class="product-highlight__selector-media">
                  {%- if product.featured_image -%}
                    <img src="{{ product.featured_image | image_url: width: 300, height: 300, crop: 'center' }}" width="300" height="300" alt="" loading="lazy">
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'product-highlight__placeholder' }}
                  {%- endif -%}
                </span>
                <span class="product-highlight__selector-title">{{ product.title | escape }}</span>
                <span class="product-highlight__selector-price">{{ price_text }}</span>
                <span class="product-highlight__selector-cta" aria-hidden="true" data-cta>{% if is_selected %}{{ selected_label }}{% else %}{{ select_label }}{% endif %}</span>
              </button>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </product-highlight>
  {%- endif -%}
</div>

{% comment %} 🛠️ is used to indicate that it's a custom section on top of this horizon theme {% endcomment %}
{% schema %}
{
  "name": "Product Highlight 🛠️",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Product Highlight 🛠️",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
